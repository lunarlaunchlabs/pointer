{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main Pointer window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "core:event:default",
    "core:path:default",
    "core:webview:default",
    "core:app:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:scope-home-recursive",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-open",
    "dialog:default",
    "store:default"
  ]
}
