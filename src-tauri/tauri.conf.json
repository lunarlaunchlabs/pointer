{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pointer",
  "version": "0.1.0",
  "identifier": "com.pointer.editor",
  "build": {
    "beforeDevCommand": "npm run icons && npm run dev",
    "beforeBuildCommand": "npm run icons && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Pointer",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#00000000",
        "shadow": true,
        "visible": true,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-first code editor with local models.",
    "longDescription": "Pointer is a lightweight, beautiful, AI-first code editor. Chat, inline edit, tab completion and agent mode powered by open-source models running locally via Ollama."
  }
}
