{
  "name": "pointer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pointer — an AI-first code editor powered by local open-source models.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/gen-icons.mjs",
    "eval": "node scripts/quality/run.mjs",
    "eval:stability": "node scripts/quality/run.mjs --rounds=5",
    "probe:commit": "node scripts/quality/gitCommitPipelineProbe.mjs",
    "assistant:terminal": "node scripts/quality/pointerTerminal.mjs",
    "eval:terminal": "node scripts/quality/pointerTerminal.mjs --suite=smoke",
    "probe:theme:meteor": "node scripts/quality/themeMeteorProbe.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.1",
    "@shikijs/monaco": "^4.1.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-fs": "^2.0.3",
    "@tauri-apps/plugin-shell": "^2.0.1",
    "@tauri-apps/plugin-store": "^2.1.0",
    "@vue/language-server": "^3.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-preact": "^1.17.0",
    "monaco-editor": "^0.52.0",
    "nanoid": "^5.0.8",
    "opencode-ai": "^1.15.11",
    "preact": "^10.29.2",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.1.0",
    "typescript-language-server": "^5.3.0",
    "vscode-langservers-extracted": "^4.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.7"
  }
}
